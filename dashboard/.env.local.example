# Supabase + Next.js environment variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Find them in: Supabase Dashboard → Project Settings → API
#
# ⚠️  NEVER commit .env.local to version control.
#     Only this .env.local.example file should be in the repository.
# ─────────────────────────────────────────────────────────────────────────────

# Your Supabase project URL
# Format: https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Your Supabase anon/public key — safe to expose to the browser.
# Used by the cookie-aware server client AND the browser client.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Your Supabase service_role key — NEVER expose to the browser.
# Used only by the /api/ingest route handler to bypass RLS.
# Find it in: Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
