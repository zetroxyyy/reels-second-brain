# =============================================================================
# Reels Second Brain — Worker Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values.
#
#   cp .env.example .env
#
# NEVER commit the real .env file to git (it's already in .gitignore).
# =============================================================================

# ── Supabase ─────────────────────────────────────────────────────────────────
# Your Supabase project URL.
# Find it at: Dashboard → Project Settings → API → Project URL
SUPABASE_URL=https://<your-project-ref>.supabase.co

# Supabase service-role key — grants full table access, bypasses RLS.
# Find it at: Dashboard → Project Settings → API → service_role (secret)
# KEEP THIS SECRET — never expose it in client-side code or logs.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Ollama ────────────────────────────────────────────────────────────────────
# URL of the Ollama server. On the same VPS this is always localhost.
# Only change this if running Ollama on a separate machine.
OLLAMA_BASE_URL=http://localhost:11434

# ── Whisper ───────────────────────────────────────────────────────────────────
# Whisper model size. Options: tiny | base | small | medium | large
# 'base' is recommended for 8 GB RAM VPS — good accuracy, ~1 GB RAM.
# Use 'small' for better quality at the cost of ~2 GB RAM.
WHISPER_MODEL=base

# ── Worker tuning ─────────────────────────────────────────────────────────────
# Seconds to sleep between polling cycles when the queue is empty.
# Lower values = more responsive queue drain but slightly more DB load.
CYCLE_SLEEP_SECONDS=10

# Directory for temporary audio files. Must be writable by the worker process.
# Files are deleted immediately after transcription. Default: /tmp/reels_worker
TEMP_DIR=/tmp/reels_worker
