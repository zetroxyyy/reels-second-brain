# =============================================================================
# Reels Second Brain — Root .gitignore
# Covers the entire monorepo: Chrome Extension + Next.js Dashboard
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# ENVIRONMENT & SECRETS — Never commit these
# ─────────────────────────────────────────────────────────────────────────────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging
.env.staging.local
# Allow the example template — it contains only placeholder values
!.env.local.example
!.env.*.example

# ─────────────────────────────────────────────────────────────────────────────
# DEPENDENCIES
# ─────────────────────────────────────────────────────────────────────────────
node_modules/
.pnpm-store/
.yarn/
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─────────────────────────────────────────────────────────────────────────────
# NEXT.JS — Dashboard build output
# ─────────────────────────────────────────────────────────────────────────────
.next/
out/
build/
dist/

# TypeScript build cache
*.tsbuildinfo
next-env.d.ts

# ─────────────────────────────────────────────────────────────────────────────
# CHROME EXTENSION — Build & packaging artifacts
# ─────────────────────────────────────────────────────────────────────────────
*.zip
*.crx
*.pem
extension-dist/
extension-build/

# ─────────────────────────────────────────────────────────────────────────────
# LOGS
# ─────────────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*
lerna-debug.log*

# ─────────────────────────────────────────────────────────────────────────────
# OPERATING SYSTEM
# ─────────────────────────────────────────────────────────────────────────────
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# Windows
Thumbs.db
Thumbs.db:encryptable
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ─────────────────────────────────────────────────────────────────────────────
# IDE & EDITORS
# ─────────────────────────────────────────────────────────────────────────────
# VS Code (keep settings if you want, but ignore secrets/local overrides)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# JetBrains (IntelliJ / WebStorm)
.idea/
*.iml
*.iws
*.ipr

# Vim / Emacs
*.swp
*.swo
*~

# ─────────────────────────────────────────────────────────────────────────────
# TESTING & COVERAGE
# ─────────────────────────────────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# Playwright / Cypress
test-results/
playwright-report/
cypress/videos/
cypress/screenshots/

# ─────────────────────────────────────────────────────────────────────────────
# MISCELLANEOUS
# ─────────────────────────────────────────────────────────────────────────────
# Temporary files
*.tmp
*.temp
*.bak
*.orig

# Vercel
.vercel

# Local helper / audit scripts (generated by the AI assistant, not project code)
audit.ps1
audit_phase2.ps1
make_icons.ps1
verify.ps1

# Supabase local dev (if used later)
.supabase/
supabase/.branches/
supabase/.temp/

#gemini said to add this
worker/.env
worker/venv/